{
  "permissions": {
    "allow": [
      "Bash(gh issue comment *)",
      "Bash(npm run puzzle:status)",
      "Edit(~/.claude/skills/log-error/SKILL.md)",
      "Edit(~/.claude/skills/puzzle-velocity/SKILL.md)",
      "Edit(~/.claude/skills/lccjs-assembly/SKILL.md)",
      "Edit(~/.claude/skills/write-til-doc/SKILL.md)"
    ]
  },
  "hooks": {
    "PostToolBatch": [
      {
        "hooks": [
          {
            "type": "command",
            "comment": "EXPERIMENT (#349) — serial-tool-use guard. Remove this block to disable. Schema confirmed from Claude Code docs (tool_calls[].{tool_name,tool_input,tool_use_id,output,was_blocked,error}).",
            "command": "node scripts/hooks/serial-tool-guard.js"
          }
        ]
      }
    ]
  }
}
