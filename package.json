{
  "name": "lccjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "jest --runInBand tests/new",
    "test:all": "jest --runInBand",
    "test:oracle": "jest --runInBand --testPathPattern oracle.e2e",
    "test:browser": "jest --runInBand tests/browser",
    "puzzle:status": "node scripts/puzzle-status.js",
    "puzzles": "bash scripts/run-pdd.sh",
    "claim": "bash scripts/claim.sh",
    "close": "exec node scripts/close.js",
    "setup": "bash scripts/setup-hooks.sh",
    "velocity:seed": "node scripts/velocity-seed.js",
    "velocity:log": "node scripts/velocity-log.js",
    "velocity:export": "node scripts/velocity-export.js",
    "velocity:migrate": "node scripts/velocity-migrate.js",
    "lccrun": "bash scripts/lccrun.sh",
    "build": "npm run build:browser && npm run build:site",
    "build:site": "node scripts/build-site.js",
    "build:browser": "webpack --config webpack.browser.config.js",
    "test:browser": "playwright test tests/browser/"
  },
  "devDependencies": {
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.2.3",
    "jest": "^29.7.0",
    "marked": "^18.0.4",
    "path-browserify": "^1.0.1",
    "playwright": "^1.60.0",
    "shiki": "^4.1.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^6.0.1"
  }
}
