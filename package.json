{
  "name": "lccjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "jest --runInBand tests/new",
    "test:all": "jest --runInBand",
    "test:oracle": "jest --runInBand --testPathPattern oracle.e2e",
    "test:parity": "jest --runInBand --testPathPattern textbook-demos.parity",
    "test:browser": "playwright test tests/browser/",
    "puzzle:status": "node scripts/puzzle-status.js",
    "puzzles": "bash scripts/run-pdd.sh",
    "preflight": "node scripts/preflight.js",
    "claim": "bash scripts/claim.sh",
    "close": "exec node scripts/close.js",
    "setup": "bash scripts/setup-hooks.sh",
    "velocity:seed": "node scripts/velocity-seed.js",
    "velocity:log": "node scripts/velocity-log.js",
    "velocity:export": "node scripts/velocity-export.js",
    "velocity:migrate": "node scripts/velocity-migrate.js",
    "error:seed": "node scripts/errors-seed.js",
    "error:log": "node scripts/error-log.js",
    "errors:export": "node scripts/errors-export.js",
    "lccrun": "bash scripts/lccrun.sh",
    "build": "npm run build:browser && npm run build:site",
    "build:site": "node scripts/build-site.js",
    "build:browser": "webpack --config webpack.browser.config.js",
    "serve:site": "node scripts/serve-site.js",
    "test:e2e": "playwright test --config playwright.e2e.config.js",
    "test:potato-tokens": "node scripts/potato-token-test.js",
    "report": "node scripts/report.js",
    "ice:score": "node scripts/ice-score.js"
  },
  "devDependencies": {
    "@lezer/highlight": "^1.2.1",
    "@lezer/lr": "^1.4.10",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.2.3",
    "jest": "^29.7.0",
    "marked": "^18.0.4",
    "path-browserify": "^1.0.1",
    "playwright": "^1.60.0",
    "process": "^0.11.10",
    "shiki": "^4.1.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^6.0.1"
  }
}
