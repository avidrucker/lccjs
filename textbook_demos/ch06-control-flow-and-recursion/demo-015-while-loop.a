; demo-015-while-loop.a
; Chapter 6: Control Flow and Recursion
; Concept: Translating a C while loop into the LCC branch pattern.
;
; WHILE LOOP PATTERN:
;   @top:  test condition
;          branch-if-false to @exit
;          ... body ...
;          br @top
;   @exit:
;
; The condition is tested at the TOP of the loop (pre-test).
; If the condition is false on entry, the body never executes.
;
; C equivalent:
;   void countdown(int x) {
;       while (x != 0) { printf("%d\n", x); x = x - 1; }
;   }
;   int main() { countdown(3); return 0; }
;
; Output: 3 2 1

startup:  bl main
          halt

; ---- countdown(int x): prints x, x-1, ..., 1 ----
countdown:
          push lr
          push fp
          mov  fp, sp

@L0:      ; @top — test condition at top of loop
          ldr  r0, fp, 2   ; r0 = x  (the argument lives at fp+2)
          cmp  r0, 0        ; test x != 0
          brz  @L1          ; if x == 0, exit the loop

          dout r0            ; printf("%d\n", x)
          nl

          ldr  r0, fp, 2    ; reload x
          sub  r0, r0, 1    ; x = x - 1
          str  r0, fp, 2    ; store back (modifying the stack copy of the arg)

          br   @L0           ; go back to test
@L1:      ; @exit
          mov  sp, fp
          pop  fp
          pop  lr
          ret

; ---- main ----
main:     push lr
          push fp
          mov  fp, sp

          mov  r0, 3
          push r0
          bl   countdown
          add  sp, sp, 1

          mov  r0, 0
          mov  sp, fp
          pop  fp
          pop  lr
          ret
