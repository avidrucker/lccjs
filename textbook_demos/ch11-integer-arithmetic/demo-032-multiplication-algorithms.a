; demo-032-multiplication-algorithms.a
; Chapter 11: Integer Arithmetic
; Concept: Two multiplication algorithms — slow (repeated addition, O(y)) vs.
;          optimized (binary method using shift instructions, O(log y)).
;
; NEW CONCEPTS:
;   srl dr, ct   — shift right logical: dr >>= ct (0 inserted on left; c = last bit shifted out)
;   sll dr, ct   — shift left logical:  dr <<= ct (0 inserted on right)
;   and dr, sr1, imm5  — dr = sr1 & imm5  (bitwise AND; also sets Z flag for while-nonzero test)
;
; SLOW MULTIPLICATION — repeated addition (O(y) steps):
;   product = 0; while (y != 0) { product += x; y--; }
;
; FAST MULTIPLICATION — binary method (O(log y) steps):
;   Examine each bit of y from LSB to MSB:
;     if (y & 1) product += x;   // if bit is set, add current power-of-x
;     y >>= 1;                   // consider next bit
;     x <<= 1;                   // x doubles each iteration
;
; Both use the register-argument convention (no stack frame):
;   r1 = x (multiplicand), r2 = y (multiplier), result in r0.
;
; C equivalent:
;   int slowmul(int x, unsigned y) { int p=0; while(y) {p+=x; y--;} return p; }
;   int mul(int x, unsigned y) { int p=0; while(y) {if(y&1)p+=x; y>>=1; x<<=1;} return p; }
;   int main() { printf("%d\n", slowmul(7,255)); printf("%d\n", mul(7,255)); }
;   // both print 1785

startup:  bl main
          halt

; ---- slowmul: r1=x, r2=y → r0=x*y ----
slowmul:  mov  r0, 0        ; product = 0
@L0:      ; @s0 — while (y != 0)
          and  r2, r2, r2   ; test y != 0  (and sets Z flag without changing r2)
          brz  @L1
          add  r0, r0, r1   ; product += x
          sub  r2, r2, 1    ; y--
          br   @L0
@L1:      ; @s1
          ret

; ---- mul: r1=x, r2=y → r0=x*y  (binary method) ----
mul:      mov  r0, 0        ; product = 0
@L2:      ; @m0 — while (y != 0)
          and  r2, r2, r2
          brz  @L3
          and  r3, r2, 1    ; if (y & 1)
          brz  @L4
          add  r0, r0, r1   ;   product += x
@L4:      ; @m2 — next bit
          srl  r2, 1        ; y >>= 1  (next bit)
          sll  r1, 1        ; x <<= 1  (x doubles)
          br   @L2
@L3:      ; @m1
          ret

main:     push lr
          push fp
          mov  fp, sp

          mov  r1, 7
          mov  r2, 255
          bl   slowmul
          dout r0  nl       ; 1785

          mov  r1, 7
          mov  r2, 255
          bl   mul
          dout r0  nl       ; 1785

          mov  r0, 0
          mov  sp, fp
          pop  fp
          pop  lr
          ret
