; demo-003-counting-loop.a
; Chapter 3: Assembly Language Basics
; Concept: A register-based counting loop — sum the first 10 odd numbers.
;
; NEW CONCEPTS:
;   mov  dr, imm       — load a small immediate value into dr (pseudo: mvi dr, imm)
;   sub  dr, sr1, imm  — dr = sr1 - imm
;   brp  label         — branch to label if N=Z (result is positive, i.e. > 0)
;
; Loop pattern:
;   initialize counter
;   loop: do work
;         decrement counter
;         brp loop       ; repeat while counter > 0
;
; C equivalent:
;   int sum = 0, odd = 1, count = 10;
;   while (count > 0) { sum += odd; odd += 2; count--; }
;   printf("Sum = %d\n", sum);   // prints: Sum = 100

          mov  r1, 0       ; r1 = sum (starts at 0)
          mov  r2, 1       ; r2 = current odd number (1, 3, 5, ...)
          mov  r3, 2       ; r3 = step (always 2, to get next odd)
          mov  r4, 10      ; r4 = loop counter (10 iterations)

loop:     add  r1, r1, r2  ; sum += current odd number
          add  r2, r2, r3  ; advance to next odd number (odd += 2)
          sub  r4, r4, 1   ; count--
          brp  loop         ; repeat while count > 0

          lea  r0, msg     ; print "Sum = "
          sout r0
          dout r1           ; print the sum (100)
          nl
          halt

; ---- data section ----
msg:      .string "Sum = "
