; demo-013-local-variables-dynamic.a
; Chapter 5: Variable Storage Classes
; Concept: Dynamic local variables — allocated on the stack, accessed via fp-relative offsets.
;
; CONCEPT:
;   Local variables live in the current stack frame.
;   They are allocated by adjusting sp downward (sub sp, sp, n OR push r0).
;   Access uses ldr/str with fp and a NEGATIVE offset.
;
;   Stack layout inside f (after prologue and local allocation):
;     fp+2  → arg a         (pushed by caller)
;     fp+1  → saved fp
;     fp+0  → saved lr
;     fp-1  → local x = 1  (allocated with  push r0  where r0=1)
;     fp-2  → local y       (allocated with  sub sp, sp, 1)
;
;   fp-1 is the FIRST local (pushed/decremented FIRST after prologue).
;   fp-2 is the SECOND local (allocated second).
;
; C equivalent:
;   void f(int a) {
;       int x = 1;
;       int y;
;       y = x + a;
;       printf("%d\n", y);   // prints 1 + 11 = 12
;   }
;   int main() { f(11); return 0; }

startup:  bl main
          halt

; ---- function f(int a) ----
f:        push lr
          push fp
          mov  fp, sp

          ; allocate and initialize local x = 1
          mov  r0, 1
          push r0           ; fp-1 = x = 1

          ; allocate (uninitialized) local y
          sub  sp, sp, 1    ; fp-2 = y (uninitialized)

          ; y = x + a
          ldr  r0, fp, -1   ; r0 = x  (fp-1)
          ldr  r1, fp,  2   ; r1 = a  (fp+2, the argument)
          add  r0, r0, r1   ; r0 = x + a
          str  r0, fp, -2   ; y = r0  (fp-2)

          ldr  r0, fp, -2   ; r0 = y
          dout r0            ; prints 12
          nl

          mov  sp, fp       ; discard locals
          pop  fp
          pop  lr
          ret

; ---- main ----
main:     push lr
          push fp
          mov  fp, sp

          mov  r0, 11       ; push arg a = 11
          push r0
          bl   f
          add  sp, sp, 1    ; pop arg

          mov  r0, 0
          mov  sp, fp
          pop  fp
          pop  lr
          ret
