; boop.ap: demonstrates the LCC+ `bop` sound alias.
; `bop` aliases to sound slot 6.
; Run:  SOUND_FILES_FROM_SYSTEM=1 node src/plus/lccplus.js plusdemos/boop.ap
        .lccplus
        lea r0, msg
        sout r0
        nl
        bop             ; alias for sound 2
        halt
msg:    .string "boop.ap: playing the bop sound slot..."
