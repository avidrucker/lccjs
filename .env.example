# Copy this file to `.env` and adjust paths for your machine.
# `.env` is gitignored; `.env.example` is committed as documentation.

# Absolute path to the original LCC oracle binary (Prof. Anthony Dos Reis's
# `cuh` package — see README "Running oracle-parity tests" for how to obtain
# and install it). Required by all *.oracle.e2e.spec.js suites.
LCC_ORACLE=/absolute/path/to/cuh63/lcc

# Optional. Max time per oracle invocation in milliseconds. Default 20000.
LCC_TIMEOUT_MS=20000

# Optional. Set to 1 to refresh golden caches when oracle output legitimately
# changes. Leave unset (or 0) in normal runs so unexpected drift is caught.
GOLDEN_AUTO_UPDATE=0

# Optional debug knobs, consumed by tests/helpers/runOracle.js:
#   KEEP_ORACLE_TMP=1   keep the oracle's per-test temp dir for inspection
#   DEBUG_ORACLE=1      log oracle stdout/stderr/exit per invocation

# Contributors — name and GitHub username for easy @-mention in issues/comments.
# Agents sourcing .env can use $CONTRIBUTOR_* vars rather than hard-coding handles.
CONTRIBUTOR_PROF_DOS_REIS=GDR400
CONTRIBUTOR_AVI_DRUCKER=avidrucker
# add others as needed
