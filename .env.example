# Copy this file to `.env` and adjust paths for your machine.
# `.env` is gitignored; `.env.example` is committed as documentation.

# Absolute path to the original LCC oracle binary (Prof. Anthony Dos Reis's
# `cuh` package — see README "Running oracle-parity tests" for how to obtain
# and install it). Required by all *.oracle.e2e.spec.js suites.
LCC_ORACLE=/absolute/path/to/cuh63/lcc

# Optional. Max time per oracle invocation in milliseconds. Default 20000.
LCC_TIMEOUT_MS=20000

# Optional. Set to 1 to refresh golden caches when oracle output legitimately
# changes. Leave unset (or 0) in normal runs so unexpected drift is caught.
GOLDEN_AUTO_UPDATE=0

# Optional debug knobs, consumed by tests/helpers/runOracle.js:
#   KEEP_ORACLE_TMP=1   keep the oracle's per-test temp dir for inspection
#   DEBUG_ORACLE=1      log oracle stdout/stderr/exit per invocation

# LCC+ sound source selection. By default, `sound 0`..`sound 6` and the aliases
# below use bundled project WAV defaults so playback is consistent across
# machines. Set SOUND_FILES_FROM_SYSTEM=1 to prefer local filesystem paths:
# per-sound LCCPLUS_SOUND_* overrides first, then known OS desktop sound paths,
# then bundled WAV files, then ASCII BEL.
SOUND_FILES_FROM_SYSTEM=0

# Optional LCC+ sound-slot overrides used only when SOUND_FILES_FROM_SYSTEM=1.
# `sound rN` reads the slot number from the runtime value stored in rN.
# The 7 slots (must match src/core/soundEngine.js SOUND_SLOTS, in order):
# LCCPLUS_SOUND_DING=/absolute/path/to/custom-ding.wav          # slot 0
# LCCPLUS_SOUND_DOINK=/absolute/path/to/custom-doink.wav        # slot 1
# LCCPLUS_SOUND_BEEP=/absolute/path/to/custom-beep.wav          # slot 2
# LCCPLUS_SOUND_PING=/absolute/path/to/custom-ping.wav          # slot 3
# LCCPLUS_SOUND_POPSOUND=/absolute/path/to/custom-popsound.wav  # slot 4
# LCCPLUS_SOUND_SOFTBEEP=/absolute/path/to/custom-softbeep.wav  # slot 5
# LCCPLUS_SOUND_BOP=/absolute/path/to/custom-bop.wav            # slot 6

# Optional. Override the `boop` logging-trap message (default "Boop!"). A trailing
# newline is appended automatically; an empty or unset value falls back to the default. (#1511)
# LCCPLUS_BOOP_MESSAGE=Beep

# Contributors — name and GitHub username for easy @-mention in issues/comments.
# This block is the SINGLE SOURCE OF TRUTH for collaborator handles (#514, #1314);
# other docs (CLAUDE.md, claude_workflow.md) point here rather than re-listing.
# Agents sourcing .env can use $CONTRIBUTOR_* vars rather than hard-coding handles.
# Validate any handle before @-mentioning: `gh api /users/<handle>` (404 = won't notify).
# UNVERIFIED: GDR400 returns 404 (as does @profavc from the old workflow-doc
# list). Real handle pending confirmation — do NOT @-mention until resolved.
CONTRIBUTOR_PROF_DOS_REIS=GDR400
CONTRIBUTOR_AVI_DRUCKER=avidrucker
CONTRIBUTOR_CHARLIE=ItBeCharlie
# add others as needed
