; Read integer; print "non-negative\n" if >= 0, else "negative\n"
        din  r0
        cmp  r0, 0
        brlt @neg
        lea  r0, @msgNN
        puts r0
        nl
        halt
@neg:   lea  r0, @msgN
        puts r0
        nl
        halt
@msgNN: .string "non-negative"
@msgN:  .string "negative"
