#!/usr/bin/env bash
# Pre-push hook for lccjs — surfaces malformed PDD puzzles before they ship.
#
# Install (one time, per clone):
#
#   ln -sf ../../scripts/git-hooks/pre-push .git/hooks/pre-push
#
# This relative symlink means the hook stays current as `scripts/git-hooks/pre-push`
# evolves on the branch you're on. If you'd rather decouple, `cp` instead of
# `ln -sf`.
#
# Behavior:
#   - Push-gating (#188): BLOCKS the push if a rebase/merge is in progress or
#     any tracked file still has conflict markers. Pushing partial state to main
#     corrupts every parallel agent's next rebase. Runs first; needs no gem.
#   - If `pdd` is not installed, prints a one-line note and exits 0 (don't
#     block the push for contributors who don't have the Ruby gem).
#   - If `pdd` is installed but `npm run puzzles` errors, prints the error
#     and blocks the push.
#
# Override with `git push --no-verify` if you really need to bypass.

set -e

cd "$(git rev-parse --show-toplevel)"

# --- Push-gating (#188, failure mode #2): never ship partial/in-progress state ---
# A push fired mid-rebase/merge, or with raw conflict markers still in tracked
# files, lands a broken tree on main and corrupts every parallel agent's next
# rebase. This guard needs no gem and runs first. Conflict markers at column 0
# never occur outside an unresolved conflict — prose that discusses them indents
# or quotes them. *.md files are excluded: markdown docs may contain fenced
# code-block examples showing what conflict markers look like (e.g. TIL docs
# explaining the close.js CSV conflict footgun), and unresolved conflicts in
# docs can't break the build (#577).
if [ -d "$(git rev-parse --git-path rebase-merge)" ] || [ -d "$(git rev-parse --git-path rebase-apply)" ]; then
  echo "[pre-push] BLOCKED — a rebase is in progress. Finish it (git rebase --continue / --abort) before pushing."
  echo "Bypass with: git push --no-verify"
  exit 1
fi
if [ -f "$(git rev-parse --git-path MERGE_HEAD)" ]; then
  echo "[pre-push] BLOCKED — an unfinished merge is in progress (MERGE_HEAD present). Commit or abort it first."
  echo "Bypass with: git push --no-verify"
  exit 1
fi
if markers=$(git grep -nE '^(<<<<<<<|>>>>>>>)' -- ':!*.md' 2>/dev/null) && [ -n "$markers" ]; then
  echo "[pre-push] BLOCKED — conflict markers in tracked files:"
  echo "$markers" | head -20
  echo "Resolve the conflict before pushing. Bypass with: git push --no-verify"
  exit 1
fi

# --- PDD puzzle scan (gem-gated) ---
if ! command -v pdd >/dev/null 2>&1; then
  echo "[pre-push] pdd not installed; skipping puzzle scan. (gem install pdd to enable.)"
  exit 0
fi

if ! command -v npm >/dev/null 2>&1; then
  echo "[pre-push] npm not installed; skipping puzzle scan."
  exit 0
fi

echo "[pre-push] scanning for PDD puzzles..."
if ! out=$(npm run --silent puzzles 2>&1); then
  echo "[pre-push] PDD scan FAILED — fix malformed puzzles before pushing."
  echo "$out" | tail -20
  echo
  echo "Bypass with: git push --no-verify"
  exit 1
fi

# Surface puzzle count as a heartbeat — helps catch sudden growth.
if [ -f puzzles.xml ]; then
  count=$(grep -c "<puzzle>" puzzles.xml || echo 0)
  echo "[pre-push] PDD scan OK — $count puzzle(s) tracked."
fi

# Reconcile markers against worktrees + GitHub issues (stale / claimed / available).
# Non-blocking: this is a heartbeat, it makes a network `gh` call and must never
# fail a push. Run `npm run puzzle:status -- --strict` manually to gate on stale.
if command -v node >/dev/null 2>&1; then
  npm run --silent puzzle:status 2>/dev/null | tail -n 2 || true
fi
