  hout r0
  nl

  ld r0, x
  mov r1, 15
  sext r0, r1
  hout r0
  nl

  ld r0, x
  mov r1, 11
  sext r0, r1
  hout r0
  nl

  ld r0, x
  mov r1, 8
  sext r0, r1
