; benchmark_isa.a — comprehensive ISA benchmark for LCC.js
;
; Covers: all mnemonics (see exclusions below), all registers r0–r7,
; all supported directives, all literal forms, labels with forward
; references, end-of-line and full-line comments.
;
; Assemble:
;   node src/core/assembler.js tests/fixtures/benchmark_isa.a
;
; Run with inputs:
;   node src/core/interpreter.js tests/fixtures/benchmark_isa.e \
;        < tests/fixtures/benchmark_isa_inputs.txt
;
; stdin inputs (in order — one per interactive prompt):
;   Line 1: A     ← ain  (single character)
;   Line 2: 42    ← din  (signed decimal integer)
;   Line 3: FF    ← hin  (hex number, no 0x prefix)
;   Line 4: hello ← sin  (string, consumed until newline)
;
; Intentionally excluded:
;   m  (trap 11) — full-memory dump; output scales with memMax,
;                  making it noisy and fragile for oracle comparison
;   bp (trap 14) — raises RuntimeError in batch mode
;   .global/.extern — force object-module (.o) output, preventing .e
;   .end — not implemented in the LCC.js assembler

        .start main

; ===================================================================
; SUBROUTINE: sub_add  —  r0 := r1 + r2
; ===================================================================
sub_add:
        push    lr
        push    fp
        mov     fp, sp
        add     r0, r1, r2
        mov     sp, fp
        pop     fp
        pop     lr
        ret

; ===================================================================
; SUBROUTINE: sub_echo  —  prints r0 as signed decimal + newline
; ===================================================================
sub_echo:
        push    lr
        push    fp
        mov     fp, sp
        dout    r0
        nl
        mov     sp, fp
        pop     fp
        pop     lr
        ret

; ===================================================================
; MAIN  (entry point via .start)
; ===================================================================
main:

; --- Debug traps at entry: registers = 0, stack = empty -----------
        r                       ; r: dump all registers (pc, ir, NZCV, r0–r7)
        s                       ; s: dump stack → "Stack empty"

; --- Frame setup --------------------------------------------------
        push    lr
        push    fp
        mov     fp, sp

; ===================================================================
; SECTION 1: MOV family — all three forms, all 8 registers (r0–r7)
; ===================================================================
        mov     r0, 1           ; decimal literal
        mvi     r1, 0xFF        ; hex literal — mvi: immediate-only form
        mvr     r2, r0          ; mvr: register-to-register copy
        mov     r3, 0xF         ; 0xF = 0b00001111 (binary literals not yet parsed by assembler)
        mov     r4, 'Z'         ; character literal
        mov     r5, -7          ; negative decimal
        mov     r6, 0           ; zero
        mov     r7, 42          ; r7 also a general-purpose register

; ===================================================================
; SECTION 2: Arithmetic — add, sub, mul, div, rem, cmp
; ===================================================================
        mov     r0, 20
        mov     r1, 6

        add     r2, r0, r1      ; register form: r2 = 26
        add     r2, r2, 4       ; immediate form: r2 = 30

        sub     r3, r0, r1      ; register form: r3 = 14
        sub     r3, r3, 2       ; immediate form: r3 = 12

        mov     r0, 10
        mov     r1, 3
        mul     r0, r1          ; r0 = 30
        mov     r0, 10
        div     r0, r1          ; r0 = 3
        mov     r0, 10
        rem     r0, r1          ; r0 = 1

        cmp     r0, r1          ; compare two registers (sets NZ flags)
        cmp     r2, 0           ; compare with immediate

; ===================================================================
; SECTION 3: Logic — and, or, xor, not, sext
; ===================================================================
        mov     r0, 0xAA        ; 0b10101010
        mov     r1, 0x0F

        and     r2, r0, r1      ; 3-operand form: r2 = 0x0A
        and     r2, r0, 0       ; immediate form: r2 = 0x00
        not     r3, r0          ; r3 = ~r0
        or      r0, r1          ; 2-operand or: r0 |= r1
        xor     r0, r1          ; 2-operand xor: r0 ^= r1

        ld      r0, val_ff      ; r0 = 0x00FF (too large for imm9 if negative)
        mov     r1, 7
        sext    r0, r1          ; sign-extend r0 from bit 7 → r0 = 0xFFFF

; ===================================================================
; SECTION 4: Shifts and Rotates — srl, sra, sll, rol, ror
; ===================================================================
        mov     r0, 16
        srl     r0, 1           ; r0 = 8  (logical right shift; carry ← 0)
        sra     r0, 1           ; r0 = 4  (arithmetic right shift)
        sll     r0, 2           ; r0 = 16 (left shift)

        ld      r1, val_8001    ; r1 = 0x8001 (large value loaded from .word)
        rol     r1, 1           ; r1 = 0x0003 (MSB wraps to LSB)
        ror     r1, 1           ; r1 = 0x8001 (LSB wraps to MSB)

; ===================================================================
; SECTION 5: Memory — ld, st, ldr, str, lea, cea
; ===================================================================
        ld      r0, data_word   ; load from label — forward ref below (r0 = 5)
        lea     r1, data_word   ; r1 = address of data_word

        ldr     r2, r1, 0       ; load via register + offset6: r2 = mem[r1+0] = 5
        add     r0, r0, 1       ; r0 = 6
        str     r0, r1, 0       ; store r0 into mem[r1+0]: data_word ← 6
        ldr     r3, r1, 0       ; verify store: r3 = 6

        mov     r4, 99
        st      r4, data_word   ; store via label: data_word ← 99

        cea     r0, 0           ; compute effective address: r0 = fp + 0

; ===================================================================
; SECTION 6: Stack — push, pop
; ===================================================================
        mov     r0, 0xBE        ; 0xBE = 190, fits in imm9
        push    r0              ; push 0xBE
        push    r1              ; push address of data_word
        pop     r2              ; pop → r2 = address of data_word
        pop     r3              ; pop → r3 = 0xBE

; ===================================================================
; SECTION 7: Control flow — bl/jsr/call, jsrr/blr, jmp, ret
; ===================================================================
        mov     r1, 3
        mov     r2, 5
        bl      sub_add         ; call via label: r0 = r1 + r2 = 8
        dout    r0              ; prints 8
        nl

        mov     r0, 42
        lea     r1, sub_echo
        jsrr    r1              ; call via register: prints 42 + newline

        ; jmp via register — jumps past an unreachable instruction
        lea     r1, jmp_land
        jmp     r1
        mov     r0, 0           ; unreachable (never executed)
jmp_land:

; ===================================================================
; SECTION 8: Branch family — all 12 condition-code mnemonics
; ===================================================================

; brz / bre — branch on zero (z = 1)
        mov     r0, 0
        cmp     r0, 0           ; z = 1
        brz     brz_ok
        mov     r0, 99          ; unreachable
brz_ok:
        bre     bre_ok          ; alias for brz — still taken (z still 1)
        mov     r0, 99          ; unreachable
bre_ok:

; brn / brlt — branch on negative (n = 1)
        mov     r0, -1
        cmp     r0, 0           ; n = 1
        brn     brn_ok
        mov     r0, 99
brn_ok:
        brlt    brlt_ok         ; alias for brn — still taken
        mov     r0, 99
brlt_ok:

; brp / brgt — branch on positive (n = 0, z = 0)
        mov     r0, 1
        cmp     r0, 0           ; n = 0, z = 0
        brp     brp_ok
        mov     r0, 99
brp_ok:
        brgt    brgt_ok         ; alias for brp
        mov     r0, 99
brgt_ok:

; brnz / brne — branch on NOT zero; not taken here (z = 1)
        mov     r0, 0
        cmp     r0, 0           ; z = 1
        brnz    nz_bad          ; NOT taken (zero → condition not met)
        br      brnz_ok
nz_bad:
        mov     r0, 99          ; unreachable
brnz_ok:
        brne    ne_bad          ; alias — also not taken
        br      brne_ok
ne_bad:
        mov     r0, 99          ; unreachable
brne_ok:

; brc / brb — branch on carry; set carry via srl shifting out a 1
        mov     r0, 1
        srl     r0, 1           ; shifts out bit 0 → c = 1
        brc     brc_ok
        mov     r0, 99          ; unreachable
brc_ok:
        mov     r0, 1
        srl     r0, 1           ; reset carry again
        brb     brb_ok          ; alias for brc
        mov     r0, 99          ; unreachable
brb_ok:

; br / bral — unconditional branch (always taken)
        br      br_ok
        mov     r0, 99          ; unreachable
br_ok:
        bral    bral_ok         ; alias for br
        mov     r0, 99          ; unreachable
bral_ok:

; ===================================================================
; SECTION 9: I/O traps
;   Output: dout, udout, hout, aout, sout, nl
;   Input:  ain, din, hin, sin
; ===================================================================

; --- ain: read single character -----------------------------------
        lea     r0, prompt_ain
        sout    r0              ; print "Enter a character: "
        ain     r0              ; read one char → 'A'
        aout    r0              ; echo the character back
        nl

; --- din: read signed decimal integer ----------------------------
        lea     r0, prompt_din
        sout    r0              ; print "Enter an integer: "
        din     r0              ; read integer → 42
        dout    r0              ; print as signed decimal
        nl
        udout   r0              ; print as unsigned decimal
        nl

; --- hin: read hex number ----------------------------------------
        lea     r0, prompt_hin
        sout    r0              ; print "Enter a hex number: "
        hin     r0              ; read hex → FF (= 255)
        hout    r0              ; print as 4-digit hex
        nl

; --- sin: read string into buffer --------------------------------
        lea     r0, prompt_sin
        sout    r0              ; print "Enter a string: "
        lea     r0, strbuf      ; r0 = address of input buffer
        sin     r0              ; read string into buffer → "hello"
        sout    r0              ; print the string
        nl

; ===================================================================
; SECTION 10: Halt
; ===================================================================
        halt

; ===================================================================
; DATA SECTION — all directive and literal forms
; ===================================================================

data_word:      .word 5                 ; .word with decimal literal
val_ff:         .word 255               ; .word with decimal (0xFF = 255)
val_8001:       .word 0x8001            ; .word with hex literal (large: used for rol/ror)

prompt_ain:     .string "Enter a character: "
prompt_din:     .string "Enter an integer: "
prompt_hin:     .string "Enter a hex number: "
prompt_sin:     .string "Enter a string: "

strbuf:         .blkw 32                ; 32-word buffer for sin result

; .org directive — advance location counter to a specific address
; (address chosen to be safely past the code and data above)
                .org 0x0200
org_marker:     .word 0xCAFE            ; .word at fixed address 0x0200
                .word 0b10101010         ; .word with binary literal (NOTE: 0b prefix parses as 0; see assembler bug)
                .word 'A'               ; .word with character literal
                .word -1                ; .word with negative decimal
